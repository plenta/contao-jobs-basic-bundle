{
  "name": "plenta/contao-jobs-basic-bundle",
  "type": "contao-bundle",
  "description": "Basic Job Manager for Contao (including Google Jobs).",
  "license": "LGPL-3.0-or-later",
  "authors": [
    {
      "name": "Plenta.io",
      "homepage": "https://plenta.io"
    }
  ],
  "funding": [{
    "type": "github",
    "url": "https://github.com/sponsors/plenta"
  }],
  "support":{
    "issues": "https://github.com/plenta/contao-jobs-basic-bundle/issues",
    "source": "https://github.com/plenta/contao-jobs-basic-bundle",
    "docs": "https://plenta.io/contao-erweiterungen/jobs-basic"
  },
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "contao/conflicts": "@dev",
    "contao/core-bundle": "^5.3",
    "doctrine/dbal": "^2.10.1 || ^3.2.0 || ^4.0",
    "mvo/contao-group-widget": "^1.5",
    "symfony/intl": "^6.0 || ^7.0 ",
    "symfony/form": "^6.0 || ^7.0",
    "contao/image": "^1.2",
    "contao/manager-plugin": "^2.13",
    "ext-intl": "*",
    "symfony/config": "^6.4 || ^7.4",
    "symfony/dependency-injection": "^6.4 || ^7.4",
    "symfony/event-dispatcher": "^6.4 || ^7.4",
    "symfony/event-dispatcher-contracts": "^3.7",
    "symfony/framework-bundle": "^6.4 || ^7.4",
    "symfony/http-foundation": "^6.4 || ^7.4",
    "symfony/http-kernel": "^6.4 || ^7.4",
    "symfony/options-resolver": "^6.4 || ^7.4",
    "symfony/routing": "^6.4 || ^7.4",
    "symfony/security-core": "^6.4 || ^7.4",
    "symfony/translation-contracts": "^3.7",
    "twig/twig": "^3.27"
  },
  "require-dev": {
    "contao/manager-bundle": "5.3.*",
    "friendsofphp/php-cs-fixer": "^3.2",
    "contao/maker-bundle": "*",
    "plenta/contao-build-tools": "@dev"
  },
  "suggest": {
    "plenta/contao-jobs-basic-contact-bundle": "Contact persons for Contao Jobs Basic",
    "plenta/contao-jobs-basic-categories-bundle": "Categories for Contao Jobs Basic",
    "plenta/contao-jobs-basic-geo-search-bundle": "GEO search for Contao Jobs Basic",
    "plenta/contao-jobs-basic-zvoove-bundle": "zvoove Connector for Contao Jobs Basic",
    "plenta/contao-jobs-basic-hansalog-hr-bundle": "HANSALOG HR Connector für Contao Jobs Basic"
  },
  "extra": {
    "contao-manager-plugin": "Plenta\\ContaoJobsBasic\\ContaoManager\\Plugin"
  },
  "autoload": {
    "psr-4": {
      "Plenta\\ContaoJobsBasic\\": "src"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "contao-components/installer": true,
      "contao/manager-plugin": true,
      "contao-community-alliance/composer-plugin": true,
      "php-http/discovery": true,
      "plenta/contao-build-tools": true
    }
  }
}
